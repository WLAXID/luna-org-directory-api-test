# ===========================================
# Organization Directory API Configuration
# ===========================================

# 🔐 API Configuration
# Секретный ключ для авторизации API запросов
# Может быть любой строкой, но рекомендуется использовать сложный ключ
API_KEY=your-secret-api-key-here

# 💾 Database Configuration
# URL подключения к базе данных
# Для SQLite: sqlite:///./data/organizations.db
# Для PostgreSQL: postgresql://user:password@localhost:5432/dbname
# Для MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./data/organizations.db

# 🌐 Application Configuration
# Название приложения (используется в документации)
APP_NAME=Organization Directory API

# Режим отладки
# true = включить детальные логи и режим разработки
# false = продакшен режим
DEBUG=true

# 🌐 CORS Configuration
# Список разрешенных источников для CORS
# Используйте ["*"] для разрешения всех источников (не рекомендуется для продакшена)
# Или укажите конкретные домены: ["https://example.com", "https://app.example.com"]
CORS_ORIGINS=["*"]

# ===========================================
# Примеры для разных окружений
# ===========================================

# === Development Environment ===
# API_KEY=dev-api-key-12345
# DATABASE_URL=sqlite:///./data/organizations.db
# DEBUG=true
# CORS_ORIGINS=["*"]

# === Staging Environment ===
# API_KEY=staging-secret-key-xyz789
# DATABASE_URL=postgresql://user:pass@staging-db:5432/organizations_staging
# DEBUG=false
# CORS_ORIGINS=["https://staging.example.com"]

# === Production Environment ===
# API_KEY=production-secure-key-abc123-def456
# DATABASE_URL=postgresql://user:pass@prod-db:5432/organizations_prod
# DEBUG=false
# CORS_ORIGINS=["https://example.com", "https://app.example.com"]
